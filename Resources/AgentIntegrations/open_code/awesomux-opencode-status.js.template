const AWESOMUX_PROTOCOL = "awesomux-agent-v1"

const sessionHookNames = {
    "session.created": "SessionStart",
    "session.idle": "Stop",
    "session.error": "StopFailure",
}

async function emitAwesoMuxHook($, hookEventName) {
    if (!hookEventName || typeof $ !== "function") {
        return
    }
    if (process.env.AWESOMUX_AGENT_EVENT_PROTOCOL !== AWESOMUX_PROTOCOL) {
        return
    }
    if (!process.env.AWESOMUX_AGENT_EVENT_FILE) {
        return
    }

    const hook = process.env.AWESOMUX_AGENT_HOOK || "awesoMuxAgentHook"
    const payload = JSON.stringify({ hook_event_name: hookEventName })

    try {
        // Bun's `$` runs commands directly (no shell), so `hook` is one literal
        // argv token even if its path contains spaces, and `payload` arrives on
        // stdin rather than argv.
        await $`${hook} --provider opencode < ${new Response(payload)}`.quiet()
    } catch {
        // Swallow errors so a missing helper or non-awesoMux host never breaks
        // the OpenCode workflow.
    }
}

export const AwesoMuxOpenCodeStatus = async ({ $ }) => {
    return {
        event: async ({ event }) => {
            await emitAwesoMuxHook($, sessionHookNames[event?.type])
        },
        "chat.message": async () => {
            await emitAwesoMuxHook($, "UserPromptSubmit")
        },
        "permission.ask": async () => {
            await emitAwesoMuxHook($, "PermissionRequest")
        },
        "tool.execute.before": async () => {
            await emitAwesoMuxHook($, "PreToolUse")
        },
        "tool.execute.after": async () => {
            await emitAwesoMuxHook($, "PostToolUse")
        },
    }
}
