<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>accessibility.sidebar.searchResultPosition</key>
    <dict>
        <key>NSStringLocalizedFormatKey</key>
        <string>%1$@, %2$lld of %3$#@results@</string>
        <key>results</key>
        <dict>
            <key>NSStringFormatSpecTypeKey</key>
            <string>NSStringPluralRuleType</string>
            <key>NSStringFormatValueTypeKey</key>
            <string>lld</string>
            <key>one</key>
            <string>⟦%3$lld result⟧</string>
            <key>other</key>
            <string>⟦%3$lld results⟧</string>
        </dict>
    </dict>
    <key>accessibility.workspaceAttention.workspacesNeedAttention</key>
    <dict>
        <key>NSStringLocalizedFormatKey</key>
        <string>%#@workspaces@</string>
        <key>workspaces</key>
        <dict>
            <key>NSStringFormatSpecTypeKey</key>
            <string>NSStringPluralRuleType</string>
            <key>NSStringFormatValueTypeKey</key>
            <string>lld</string>
            <key>one</key>
            <string>⟦attention:%lld workspace⟧</string>
            <key>other</key>
            <string>⟦attention:%lld workspaces⟧</string>
        </dict>
    </dict>
</dict>
</plist>
